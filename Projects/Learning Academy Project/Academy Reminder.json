    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nreturn items.map(item => {\n  const rawData = item.json;\n\n  const formatToInternational = (phone) => {\n    if (!phone) return null;\n    \n    let cleaned = phone.toString().replace(/\\D/g, '');\n    \n    if (cleaned.startsWith('0')) {\n      cleaned = '20' + cleaned.substring(1);\n    }\n    \n    // إذا كان الرقم 10 أرقام (صيغة مصرية بدون كود الدولة وبدون الصفر الأول)\n    if (cleaned.length === 10 && (cleaned.startsWith('1'))) {\n        cleaned = '20' + cleaned;\n    }\n    \n    // إذا كان الرقم 11 رقم ويبدأ بـ 1 (حالة نادرة بدون صفر)\n    if (cleaned.length === 11 && cleaned.startsWith('1')) {\n        cleaned = '2' + cleaned;\n    }\n\n    return cleaned;\n  };\n\n  return {\n    json: {\n      ...rawData,\n      // التعديل هنا: استخدمنا الاسم الصحيح للحقل كما يظهر في بياناتك\n      student_whatsapp_clean: formatToInternational(rawData[\"Student WhatsApp\"]) \n    }\n  };\n});"
      },
