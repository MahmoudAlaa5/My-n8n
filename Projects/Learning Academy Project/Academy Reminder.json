    {
      "parameters": {
        "jsCode": "const now = new Date();\nconst tomorrowDate = new Date();\ntomorrowDate.setDate(now.getDate() + 1);\n\nconst results = [];\n\nfor (const item of $input.all()) {\n  const scheduleText = item.json[\"Student's Schedual\"]; \n  \n  // 1. تعديل الـ Regex ليتجاهل الأقواس ويستخرج الوقت بدقة\n  const timeMatch = scheduleText.match(/(\\d{1,2}:\\d{2}\\s?(AM|PM))/i);\n  \n  if (timeMatch) {\n    const timeString = timeMatch[1];\n    \n    // 2. بناء تاريخ الموعد\n    const parts = timeString.split(/\\s+/); // تقسيم النص بناءً على المسافة\n    const timePart = parts[0];\n    const modifier = parts[1];\n    \n    let [hours, minutes] = timePart.split(':');\n    \n    if (modifier.toUpperCase() === 'PM' && hours !== '12') {\n      hours = parseInt(hours, 10) + 12;\n    }\n    if (modifier.toUpperCase() === 'AM' && hours === '12') {\n      hours = 0;\n    }\n\n    const appointmentDate = new Date(tomorrowDate);\n    appointmentDate.setHours(parseInt(hours, 10), parseInt(minutes, 10), 0, 0);\n\n    // 3. حساب الفرق بالساعات\n    const diffInMs = appointmentDate - now;\n    const diffInHours = diffInMs / (1000 * 60 * 60);\n\n    // 4. الفلترة (المواعيد التي ستبدأ خلال 30 ساعة)\n    if (diffInHours > 0 && diffInHours <= 30) { \n      results.push({\n        json: {\n          ...item.json,\n          hoursUntilAppointment: diffInHours.toFixed(2),\n          appointmentTimeOnly: timeString, // سنحتاجها في رسالة الواتساب\n          appointmentStatus: \"Reminder Ready\"\n        }\n      });\n    }\n  }\n}\n\n// الـ return يجب أن تكون خارج الـ Loop تماماً\nreturn results;"
      },
