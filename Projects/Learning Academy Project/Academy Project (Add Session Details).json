    {
      "parameters": {
        "jsCode": "// 1. جلب الساعات الحالية من الشيت\nlet currentHoursInSheet = parseFloat($input.first().json['Total Hours']) || 0;\n\n// 2. جلب كل الـ items (loop)\nlet items = $input.all();\n\nlet totalNewHours = 0;\n\n// 3. عمل loop على كل session duration\nfor (let item of items) {\n\n  let newSessionRaw = $('Females').first().json['Session\\'s Duration'] || \"0\";\n\n  // استخراج الدقائق فقط\n  let newMinutes = parseInt(newSessionRaw.replace(/\\D/g, '')) || 0;\n\n  // تحويل إلى ساعات\n  let newHours = newMinutes / 60;\n\n  // جمع الساعات\n  totalNewHours += newHours;\n}\n\n// 4. جمع الساعات القديمة + الجديدة\nlet updatedTotal = currentHoursInSheet + totalNewHours;\n\nreturn {\n  finalHours: Number(updatedTotal.toFixed(2)),\n  addedNow: Number(totalNewHours.toFixed(2))\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
