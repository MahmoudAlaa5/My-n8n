      "name": "If2"
    },
    {
      "parameters": {
        "jsCode": "// 1. جلب قائمة المواعيد المحجوزة من العقدة الأولى (المدخل 0)\nconst inputFromNode1 = $input.all(0);\nconst scheduleListElement = inputFromNode1.find(item => item.json.is_schedule_list === true);\nconst bookedSchedules = scheduleListElement ? scheduleListElement.json.all_teacher_schedules : [];\n\n// 2. جلب موعد الطالب الجديد من العقدة الثانية (المدخل 1)\nconst studentChoice = $input.all(1)[0].json;\nconst selectedSchedule = String(studentChoice.TeacherSchedual || \"\").trim();\n\n// 3. اللوب للمقارنة:\n// سنفترض أولاً أن الموعد متاح (true)\nlet isAvailable = true; \n\nfor (const booked of bookedSchedules) {\n  // إذا وجدنا تطابقاً واحداً فقط، فهذا يعني أن الموعد \"غير متاح\"\n  if (String(booked).trim() === selectedSchedule) {\n    isAvailable = false; // وجدنا الموعد محجوزاً\n    break; // نخرج من اللوب فوراً، لا داعي لإكمال الفحص\n  }\n}\n\n// 4. إرجاع النتيجة\nreturn {\n  json: {\n    ...studentChoice,\n    isScheduleAvailable: isAvailable // ترجع true إذا كان الموعد متاحاً، و false إذا كان محجوزاً\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
