    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nreturn items.map(item => {\n  const rawData = item.json;\n\n  // وظيفة تنظيف رقم الواتساب\n  const formatToInternational = (phone) => {\n    if (!phone) return null;\n    let cleaned = phone.toString().replace(/\\D/g, '');\n    if (cleaned.startsWith('0')) {\n      cleaned = '20' + cleaned.substring(1);\n    }\n    if (cleaned.length === 10 && (cleaned.startsWith('1') || cleaned.startsWith('5'))) {\n        cleaned = '20' + cleaned;\n    }\n    return cleaned;\n  };\n\n  // تنظيف رقم الطالب أولاً\n  const cleanedPhone = formatToInternational(rawData[\"Student WhatsApp\"]);\n\n  // استخراج آخر 4 أرقام من الرقم المنظف (إذا وجد الرقم)\n  const studentIdFromPhone = cleanedPhone ? cleanedPhone.slice(-4) : \"0000\";\n\n  return {\n    json: {\n      student_id: studentIdFromPhone, // آخر 4 أرقام من الهاتف\n      student_whatsapp_clean: cleanedPhone,\n      teacher_whatsapp_clean: formatToInternational(rawData[\"Teacher WhatsApp\"]),\n      registration_date: rawData[\"submittedAt\"] ? new Date(rawData[\"submittedAt\"]).toISOString().split('T')[0] : new Date().toISOString().split('T')[0]\n    }\n  };\n});"
      },
