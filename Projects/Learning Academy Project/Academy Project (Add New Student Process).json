    {
      "parameters": {
        "jsCode": "const newId = $('Code in JavaScript').first().json.student_id;\nconst existingRows = $input.all(); \nconst StudentName = $('On form submission').first().json['Student Name'];// بفرض أن هذا المدخل هو بيانات الشيت\n\nconst TeacherName = $('On form submission').first().json['Teacher Name'];\nconst TeacherScheduel = $('On form submission').first().json['Student Schedule '];\n\n// البحث عن أي تطابق\nconst isFound = existingRows.some(row => row.json['Student ID'] == newId);\n\nreturn {\n  isDuplicate: isFound,\n  newId: newId,\n  StudentName: StudentName,\n  TeacherName: TeacherName,\n  TeacherSchedual: TeacherScheduel\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1264,
        32
      ],
      "id": "fafc0487-3146-494b-9ca5-56ef7d62c584",
      "name": "Code in JavaScript2"
    },
    {
      "parameters": {
        "jsCode": "// جلب المجموعتين\nconst students = $input.all(0);\nconst teacherRows = $input.all(1);\n\n// استخراج المواعيد في قائمة واحدة ونظيفة\nconst allSchedules = teacherRows.map(row => row.json[\"Student's Schedual\"]).filter(s => s);\n\n// تحويل الطلاب لتنسيق n8n\nconst studentResults = students.map(s => ({ json: s.json }));\n\n// إضافة عنصر واحد فقط يحتوي على كل المواعيد في نهاية القائمة\nstudentResults.push({\n  json: {\n    is_schedule_list: true,\n    all_teacher_schedules: allSchedules\n  }\n});\n\nreturn studentResults;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1072,
        32
      ],
      "id": "4d227ccc-d99a-40a1-ac4e-d22a84d476db",
      "name": "Code in JavaScript1"
    },
